#include <stdio.h>

struct student {
    char name[50];
    float marks;
};

int main() {
    struct student s[3];
    int max = 0;

    for(int i = 0; i < 3; i++) {
        printf("Enter Name and Marks: ");
        scanf("%s %f", s[i].name, &s[i].marks);

        if(s[i].marks > s[max].marks)
            max = i;
    }

    printf("\nTopper: %s (%.2f)", s[max].name, s[max].marks);

    return 0;
}
