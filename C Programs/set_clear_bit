#include <stdio.h>

int main()
{
    int num, pos, choice;

    printf("Enter number: ");
    scanf("%d", &num);

    printf("\n1.Set bit");
    printf("\n2.Clear bit");

    printf("\nEnter choice: ");
    scanf("%d", &choice);

    printf("Enter position: ");
    scanf("%d", &pos);

    if(choice == 1)
    {
        num = num | (1 << pos);
        printf("Result = %d", num);
    }
    else if(choice == 2)
    {
        num = num & ~(1 << pos);
        printf("Result = %d", num);
    }
    else
    {
        printf("Wrong choice");
    }

    return 0;
}
